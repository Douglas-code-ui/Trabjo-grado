<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".Crear">

    <!-- Usamos un LinearLayout con width match_parent para que todo se alinee bien -->
    <LinearLayout
        android:id="@+id/linearRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:gravity="center_horizontal">

        <!-- TITULO (centrado) -->
        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear cuenta"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- ETIQUETA NOMBRE -->
        <TextView
            android:id="@+id/labelNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textColor="#000000"
            android:textSize="16sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/txtNombre"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_bacground"
            android:inputType="textPersonName"
            android:padding="12dp" />

        <!-- ETIQUETA CORREO -->
        <TextView
            android:id="@+id/labelCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correo electrónico"
            android:textColor="#000000"
            android:textSize="16sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/txtCorreo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_bacground"
            android:inputType="textEmailAddress"
            android:padding="12dp" />

        <!-- ETIQUETA CONTRASEÑA -->
        <TextView
            android:id="@+id/labelContrasena"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textColor="#000000"
            android:textSize="16sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/txtContrasena"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_bacground"
            android:inputType="textPassword"
            android:padding="12dp" />

        <!-- RADIOGROUP centrado -->
        <RadioGroup
            android:id="@+id/radioTipoUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="28dp">

            <!-- Cada RadioButton con layout_width wrap_content y gravity center -->
            <RadioButton
                android:id="@+id/rbEmpleado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Empleado"
                android:textColor="#000000"
                android:textSize="16sp"
                android:buttonTint="#000000"
                android:layout_marginBottom="10dp" />

            <RadioButton
                android:id="@+id/rbAdministrador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Administrador"
                android:textColor="#000000"
                android:textSize="16sp"
                android:buttonTint="#000000" />
        </RadioGroup>

        <!-- BOTON Crear centrarlo con layout_gravity -->
        <Button
            android:id="@+id/btnCrear"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:text="Crear"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@null" />


        <!-- separación final para que no quede pegado -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
