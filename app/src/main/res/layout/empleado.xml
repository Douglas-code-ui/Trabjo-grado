<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".Empleado">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- BUSCADOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edittext_bacground"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/serch" />

            <EditText
                android:id="@+id/txtBuscar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="Buscar"
                android:textColor="#000000"
                android:paddingLeft="10dp"
                android:inputType="text" />
        </LinearLayout>

        <!-- ICONO CONFIGURACIÓN -->
        <ImageView
            android:id="@+id/btnConfig"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:src="@drawable/confi"
            android:layout_marginBottom="28dp" />

        <!-- TARJETA USUARIO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@drawable/edittext_bacground"
            android:layout_marginBottom="40dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/user"
                android:layout_marginRight="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNombreEmpleado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtRolEmpleado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="#000000" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/user"
                        android:layout_marginLeft="6dp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- BOTON BUZOS -->
        <Button
            android:id="@+id/btnBuzos"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:text="Buzos"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@null"
            android:layout_marginBottom="28dp" />

        <!-- BOTON PANTALONES -->
        <Button
            android:id="@+id/btnPantalones"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:text="Pantalones"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@null"
            android:layout_marginBottom="28dp" />

        <!-- BOTON REGISTRAR VENTA -->
        <Button
            android:id="@+id/btnRegistrarVenta"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:text="Registrar venta"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@null"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>
