<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TÍTULO -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buzos"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_alignParentStart="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Campana -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imgNotificacion"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/bell"
                        android:padding="2dp"/>

                    <TextView
                        android:id="@+id/txtContador"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="end|top"
                        android:background="@drawable/circulo_rojo"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:visibility="gone"/>
                </FrameLayout>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/confi"/>

            </LinearLayout>

        </RelativeLayout>

        <!-- BUSCADOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/edittext_bacground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <ImageView
                android:id="@+id/btnBuscar"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/serch"/>

            <EditText
                android:id="@+id/txtBuscar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Buscar"
                android:paddingLeft="12dp"/>

        </LinearLayout>

        <!-- CARRUSEL 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#DDDDDD"
            android:gravity="center">

            <ImageView
                android:id="@+id/btnPrev1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/fl1"/>

            <ImageView
                android:id="@+id/imgCarrusel1"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginLeft="32dp"
                android:layout_marginRight="32dp"
                android:src="@drawable/buzo1"/>

            <ImageView
                android:id="@+id/btnNext1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/fl2"/>

        </LinearLayout>

        <TextView
            android:id="@+id/txtNombre1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Nombre buzo"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtPrecio1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/txtStock1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Stock: 0"
            android:textSize="16sp"/>

        <!-- CARRUSEL 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#DDDDDD"
            android:gravity="center">

            <ImageView
                android:id="@+id/btnPrev2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/fl1"/>

            <ImageView
                android:id="@+id/imgCarrusel2"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginLeft="32dp"
                android:layout_marginRight="32dp"
                android:src="@drawable/buzo2"/>

            <ImageView
                android:id="@+id/btnNext2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/fl2"/>

        </LinearLayout>

        <TextView
            android:id="@+id/txtNombre2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Nombre buzo"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtPrecio2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/txtStock2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Stock: 0"
            android:textSize="16sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

    </LinearLayout>

</ScrollView>